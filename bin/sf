#!/bin/bash

# SF - Star Forge
# Main dispatcher script for sf subcommands

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
SCRIPTS_DIR="$PROJECT_DIR/scripts"

# Initialize environment if not already in Star Forge shell
if [[ -z "$STAR_FORGE_SHELL" ]]; then
    if [[ $EUID -ne 0 ]]; then
        echo "Elevating to root..."
        exec sudo -E bash "$0" "$@"
    fi

    source "$SCRIPTS_DIR/init.sh"

    if [[ $# -eq 0 ]]; then
        enter_env  # Launches shell, never returns
    fi

    setup_env
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

show_usage() {
    echo "SF - Star Forge"
    echo ""
    echo "Usage: sf <command> [arguments]"
    echo ""
    echo "Available commands:"

    for script in "$SCRIPTS_DIR"/sf_*.sh; do
        if [[ -f "$script" ]]; then
            name=$(basename "$script" .sh)
            cmd_name="${name#sf_}"
            echo "  $cmd_name"
        fi
    done

    echo ""
    echo "Examples:"
    echo "  sf mount              # Mount the current target"
    echo "  sf set-target prod    # Set active target to 'prod'"
    echo "  sf status             # Show mount status and target info"
    echo "  sf clone-target dev staging \"Staging environment\""
    echo ""
}

if [[ $# -eq 0 ]]; then
    show_usage
    exit 0
fi

SUBCOMMAND="$1"
shift

SCRIPT_NAME="sf_${SUBCOMMAND}.sh"
SCRIPT_PATH="$SCRIPTS_DIR/$SCRIPT_NAME"

if [[ ! -f "$SCRIPT_PATH" ]]; then
    echo -e "${RED}Error: Unknown command '$SUBCOMMAND'${NC}" >&2
    echo ""
    show_usage
    exit 1
fi

exec bash "$SCRIPT_PATH" "$@"
